{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "https": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "https://localhost:7207",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Production",
        
        "Serilog__Using__0": "Serilog.Sinks.Console",
        "Serilog__MinimumLevel__Default": "Debug",
        "Serilog__WriteTo__0__Name": "Console",
        "Serilog__WriteTo__0__Args__theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
        "Serilog__WriteTo__1__Name": "OpenTelemetry",
        "Serilog__WriteTo__1__Args__Protocol": "Grpc",
        
        "Tesseract__Path": "D:/tesseract",
        "Tesseract__Language": "rus+eng",
        
        "Sso__Authority": "http://localhost:8080/realms/development",
        "Sso__IncludeErrorDetails": "true",
        "Sso__RequireHttpsMetadata": "false",
        "Sso__TokenValidationParameters__ValidIssuer": "client",
        "Sso__TokenValidationParameters__ValidAudiences__0": "ocr",
        "Sso__TokenValidationParameters__ValidateAudience": "true",
        "Sso__TokenValidationParameters__ValidateLifetime": "true",
        "Sso__TokenValidationParameters__ValidateIssuer": "true",
        "Sso__TokenValidationParameters__ValidateIssuerSigningKey": "true",

        "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4317",
        "OTEL_SERVICE_NAME": "Ocr"
      }
    }
  }
}
